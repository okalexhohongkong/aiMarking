# 企业微信智能机器人配置
# 在企业微信管理后台创建“智能机器人”后填写。
WECOM_BOT_ID=
WECOM_BOT_SECRET=
# 可选：私有部署企业如果后台给了专用长连接地址，再填写。
WECOM_WS_URL=

# 机器人在群里被叫的名字。群里 @ 这个名字，才会触发知识库回答。
BOT_MENTION_NAME=智能客服
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8787

# OpenAI/CCX 兼容接口配置
# 如果用本机 CCX Desktop，通常是 http://127.0.0.1:3688/v1
OPENAI_BASE_URL=http://127.0.0.1:3688/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 知识库说明。把“奥普C在”的知识库名称、范围或答题要求写在这里。
KNOWLEDGE_BASE_NAME=奥普C在知识库
KNOWLEDGE_SYSTEM_PROMPT=你是黑卫士七维AI营销系统的客服承接助手，只能根据奥普C在知识库回答。答案要简洁、准确；不知道时请说明需要人工确认。

# 可选：限制回答长度，避免刷屏
MAX_REPLY_CHARS=900

# 多平台客服端口预留。1.0 先展示端口和配置状态，拿到对应平台权限后逐个接入。
# 微信小程序客服
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=
WECHAT_MINIAPP_TOKEN=

# 个人微信信使中转，优先用于人工确认后的辅助承接
EASYCLAW_BASE_URL=http://127.0.0.1:10027
EASYCLAW_ACCESS_TOKEN=

# 抖音 / 快手 / 小红书 / 视频号
DOUYIN_APP_ID=
DOUYIN_APP_SECRET=
KUAISHOU_APP_ID=
KUAISHOU_APP_SECRET=
XHS_APP_ID=
XHS_APP_SECRET=
WECHAT_CHANNELS_APP_ID=
WECHAT_CHANNELS_APP_SECRET=

# 电商客服端口，默认只做平台内承接，不直接站外引流
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=
JD_APP_KEY=
JD_APP_SECRET=

# 短信、资讯内容平台和海外社媒端口。1.0 先做端口占位和模拟，真实触达必须遵守平台权限、用户授权和频控规则。
SMS_PROVIDER=
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
TOUTIAO_APP_ID=
TOUTIAO_APP_SECRET=
BAIJIAHAO_APP_ID=
BAIJIAHAO_APP_SECRET=
BILIBILI_APP_KEY=
BILIBILI_APP_SECRET=
ZHIHU_CLIENT_ID=
ZHIHU_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_TOKEN=
X_TWITTER_API_KEY=
X_TWITTER_API_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
