        "效果指标",
        "案例资料"
      ],
      "steps": [
        "先确认客户所属行业或场景",
        "说明可以按相似场景提供案例",
        "提醒案例只能作为参考，最终方案要按实际需求判断",
        "引导客户领取客户案例集"
      ],
